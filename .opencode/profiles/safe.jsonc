{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "default_run_agent": "sisyphus",
  "agents": {
    "sisyphus": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": ["opencode/kimi-k2.5", "opencode/glm-5"]
    },
    "prometheus": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["kimi-for-coding/k2p5", "opencode/kimi-k2.5", "opencode/gpt-5.2"]
    },
    "atlas": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": ["openai/gpt-5.2", "opencode/kimi-k2.5"]
    },
    "metis": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": ["openai/gpt-5.2", "opencode/glm-5"]
    },
    "hephaestus": {
      "model": "openai/gpt-5.2-codex",
      "fallback_models": ["opencode/gpt-5.2-codex", "openai/gpt-5.1-codex"]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["opencode/gpt-5.2", "kimi-for-coding/k2p5"]
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "fallback_models": ["opencode/gpt-5.2", "kimi-for-coding/k2p5"]
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": ["opencode/minimax-m2.5", "opencode/gpt-5-nano"]
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": ["opencode/glm-4.7", "opencode/big-pickle"]
    },
    "multimodal-looker": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": ["opencode/kimi-k2.5", "openai/gpt-5.2", "opencode/gemini-3-flash"]
    }
  },
  "categories": {
    "ultrabrain": { "model": "openai/gpt-5.2-codex" },
    "deep": { "model": "openai/gpt-5.2-codex" },
    "artistry": { "model": "kimi-for-coding/k2p5" },
    "quick": { "model": "opencode/minimax-m2.5-free" },
    "unspecified-low": { "model": "kimi-for-coding/k2p5" },
    "unspecified-high": { "model": "openai/gpt-5.2" },
    "visual-engineering": { "model": "kimi-for-coding/k2p5" },
    "writing": { "model": "kimi-for-coding/k2p5" }
  },
  "runtime_fallback": {
    "enabled": true,
    "max_fallback_attempts": 2,
    "cooldown_seconds": 3
  },
  "ralph_loop": {
    "enabled": false,
    "default_max_iterations": 60,
    "default_strategy": "continue"
  },
  "babysitting": {
    "timeout_ms": 90000
  },
  "background_task": {
    "defaultConcurrency": 2,
    "providerConcurrency": {
      "openai": 1,
      "kimi-for-coding": 1,
      "opencode": 2
    },
    "modelConcurrency": {
      "openai/gpt-5.2-codex": 1,
      "openai/gpt-5.2": 1,
      "kimi-for-coding/k2p5": 1,
      "opencode/minimax-m2.5-free": 3
    }
  }
}
