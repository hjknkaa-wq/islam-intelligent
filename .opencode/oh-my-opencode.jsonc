{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "auto_update": true,
  "default_run_agent": "sisyphus",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "planner_enabled": true,
    "replace_plan": true
  },
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 503, 529],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 2,
    "timeout_seconds": 35
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "temperature": 0.1,
      "fallback_models": [
        "openai/gpt-5.2-codex",
        "omniroute/cx/gpt-5.3-codex-high"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "temperature": 0.1,
      "fallback_models": [
        "omniroute/cx/gpt-5.3-codex-high",
        "openai/gpt-5.2-codex"
      ]
    },
    "explore": {
      "model": "opencode/gpt-5-nano",
      "temperature": 0.1,
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "librarian": {
      "model": "omniroute/cx/gpt-5.3-codex-high",
      "temperature": 0.2,
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "atlas": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "fallback_models": [
        "opencode/gpt-5-nano",
        "omniroute/qw/qwen3-coder-flash"
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "temperature": 0.1,
      "fallback_models": [
        "omniroute/cx/gpt-5.2"
      ]
    },
    "multimodal-looker": {
      "model": "omniroute/cx/gpt-5.3-codex-high",
      "temperature": 0.1,
      "fallback_models": [
        "opencode/gemini-3-flash"
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "opencode/gpt-5-nano",
      "temperature": 0.1,
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "temperature": 0.1,
      "fallback_models": [
        "omniroute/cx/gpt-5.3-codex-high"
      ]
    },
    "ultrabrain": {
      "model": "omniroute/cx/gpt-5.3-codex-xhigh",
      "temperature": 0.1,
      "fallback_models": [
        "openai/gpt-5.3-codex"
      ]
    },
    "writing": {
      "model": "omniroute/cx/gpt-5.3-codex-high",
      "temperature": 0.2,
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "visual-engineering": {
      "model": "omniroute/cx/gpt-5.3-codex-high",
      "temperature": 0.2,
      "fallback_models": [
        "opencode/gemini-3-flash"
      ]
    },
    "islam-etl": {
      "model": "omniroute/qw/qwen3-coder-flash",
      "temperature": 0.1,
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "islam-rag": {
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "fallback_models": [
        "omniroute/cx/gpt-5.3-codex-high"
      ]
    },
    "islam-security": {
      "model": "openai/gpt-5.2-codex",
      "temperature": 0.1,
      "fallback_models": [
        "omniroute/cx/gpt-5.2-codex"
      ]
    }
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 100,
    "default_strategy": "continue"
  },
  "background_task": {
    "defaultConcurrency": 6,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "openai": 2,
      "omniroute": 3,
      "opencode": 6
    },
    "modelConcurrency": {
      "openai/gpt-5.3-codex": 1,
      "omniroute/cx/gpt-5.3-codex-high": 2,
      "omniroute/qw/qwen3-coder-plus": 3,
      "omniroute/qw/qwen3-coder-flash": 5,
      "opencode/minimax-m2.5-free": 8,
      "opencode/gpt-5-nano": 8
    }
  },
  "experimental": {
    "task_system": true,
    "auto_resume": true
  }
}
