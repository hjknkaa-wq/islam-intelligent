POSTGRES_DB=islam_intelligent
POSTGRES_USER=islam_intelligent
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

API_PORT=8000
UI_PORT=3000
APP_ENV=development

DATABASE_URL=postgresql+psycopg://islam_intelligent:change-me@postgres:5432/islam_intelligent
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# RAG and LLM Configuration
RAG_ENABLE_LLM=false
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_SEED=42
RAG_LLM_BASE_URL=

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5

# Reranker Configuration
RAG_ENABLE_RERANKER=true
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_RERANKER_TOP_K=10
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# HyDE Configuration
HYDE_ENABLED=true
HYDE_MAX_TOKENS=256

# Query Expansion Configuration
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_COUNT=3

# Budget and Quality Thresholds
DAILY_BUDGET_USD=10.0
FAITHFULNESS_THRESHOLD=0.7

# Observability
METRICS_ENABLED=false

# Neo4j
NEO4J_AUTH=neo4j/change-me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# API Keys (set in environment, not committed)
# OPENAI_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com