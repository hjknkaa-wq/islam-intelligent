{
  "$schema": "https://opencode.ai/config.json",

  // Default model for this project.
  // Format: provider/model (OpenCode standard) :contentReference[oaicite:3]{index=3}
  "model": "openai/gpt-5.2",
  "small_model": "opencode/gpt-5-nano",

  // Optional: global model tuning (agent-level overrides still apply)
  "provider": {
    "openai": {
      "models": {
        "gpt-5.2": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  }
}